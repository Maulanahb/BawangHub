rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      // NOTE: We check the email instead of a document field to bootstrap easier, or check a field
      // Let's check `is_admin` field in their user document (or specifically admin email).
      return isSignedIn() && 
             (
               request.auth.token.email == 'maulanahmad2287@gmail.com' ||
               (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('is_admin', false) == true)
             );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['userId', 'createdAt', 'updatedAt']) &&
             data.userId == request.auth.uid &&
             (data.get('name', '') is string) &&
             (data.get('email', '') is string) &&
             (data.get('landArea', 0) is number) &&
             (data.get('landLocation', '') is string) &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    match /users/{userId} {
      allow get: if isSignedIn() && isValidId(userId) && (userId == request.auth.uid || isAdmin());
      allow list: if isAdmin(); // Open for admin dashboard counting

      allow create: if isSignedIn() && isValidId(userId) &&
        userId == request.auth.uid &&
        isValidUser(incoming()) &&
        incoming().createdAt == request.time &&
        incoming().updatedAt == request.time;

      allow update: if isSignedIn() && isValidId(userId) &&
        userId == request.auth.uid &&
        isValidUser(incoming()) &&
        incoming().userId == existing().userId &&
        incoming().createdAt == existing().createdAt &&
        incoming().updatedAt == request.time &&
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'email', 'landArea', 'landLocation', 'updatedAt']);
    }

    function isValidHistory(data) {
      return data.keys().hasAll(['userId', 'type', 'title', 'data', 'createdAt']) &&
             data.userId == request.auth.uid &&
             (data.type == 'kalkulator' || data.type == 'klinik') &&
             data.title is string && data.title.size() <= 200 &&
             data.data is map &&
             data.createdAt is timestamp;
    }

    match /users/{userId}/history/{historyId} {
      allow get: if isSignedIn() && isValidId(userId) && isValidId(historyId) && userId == request.auth.uid;
      allow list: if isSignedIn() && isValidId(userId) && userId == request.auth.uid;

      allow create: if isSignedIn() && isValidId(userId) && isValidId(historyId) &&
        userId == request.auth.uid &&
        isValidHistory(incoming()) &&
        incoming().createdAt == request.time;
      
      allow update, delete: if false; // history is immutable
    }

    function isValidThread(data) {
      return data.keys().hasAll(['userId', 'userName', 'judul', 'isi_pesan', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.userName is string && data.userName.size() <= 100 &&
             data.judul is string && data.judul.size() <= 200 &&
             data.isi_pesan is string && data.isi_pesan.size() <= 5000 &&
             data.createdAt is timestamp;
    }

    match /threads/{threadId} {
      allow get: if isSignedIn() && isValidId(threadId);
      allow list: if isSignedIn();

      allow create: if isSignedIn() && isValidId(threadId) &&
        isValidThread(incoming()) &&
        incoming().createdAt == request.time;

      allow update: if false; 
      allow delete: if isAdmin();
    }

    function isValidReply(data) {
      return data.keys().hasAll(['threadId', 'userId', 'userName', 'isi_balasan', 'is_ai_generated', 'createdAt']) &&
             (data.userId == request.auth.uid || data.userId == 'bawang-bot') &&
             data.threadId is string && data.threadId.size() <= 128 &&
             data.userName is string && data.userName.size() <= 100 &&
             data.isi_balasan is string && data.isi_balasan.size() <= 10000 &&
             data.is_ai_generated is bool &&
             data.createdAt is timestamp;
    }

    match /threads/{threadId}/replies/{replyId} {
      allow get: if isSignedIn() && isValidId(threadId) && isValidId(replyId);
      allow list: if isSignedIn() && isValidId(threadId);

      allow create: if isSignedIn() && isValidId(threadId) && isValidId(replyId) &&
        isValidReply(incoming()) &&
        incoming().threadId == threadId &&
        exists(/databases/$(database)/documents/threads/$(threadId)) &&
        incoming().createdAt == request.time;

      allow update: if false;
      allow delete: if isAdmin();
    }

    match /{path=**}/replies/{replyId} {
      allow list: if isAdmin();
    }

    function isValidFeedback(data) {
      return data.keys().hasAll(['userId', 'email', 'message', 'type', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.email is string &&
             data.message is string && data.message.size() <= 2000 &&
             data.type is string &&
             data.createdAt is timestamp;
    }

    match /feedbacks/{feedbackId} {
      allow create: if isSignedIn() && isValidFeedback(incoming()) && incoming().createdAt == request.time;
    }
  }
}
